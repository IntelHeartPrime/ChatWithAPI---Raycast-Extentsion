# OpenAI 兼容 API 配置示例
# 复制此文件为 .env 并填入你的实际值

# 通用 API Key
API_KEY=your-api-key-here

# 模型名
MODEL=deepseek/deepseek-r1

# OpenAI 兼容 base_url
# OpenAI 官方: https://api.openai.com/v1
# JieKou AI: https://api.jiekou.ai/openai
API_BASE_URL=https://api.openai.com/v1

# 代理 URL（可选，如果在中国大陆需要）
PROXY_URL=http://127.0.0.1:7890

# 某些中转平台可选支持的请求头
REFERER_URL=
APP_TITLE=
